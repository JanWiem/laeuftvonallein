    const val = document.getElementById('pw-input').value;
    if (val === PASSWORT) {
      sessionStorage.setItem('lva_auth', '1');
      document.getElementById('pw-overlay').classList.add('hidden');
    } else {
      const inp = document.getElementById('pw-input');
      document.getElementById('pw-error').textContent = 'Falsches Passwort – bitte erneut versuchen.';
      inp.value = '';
      inp.classList.remove('shake');
      void inp.offsetWidth;
      inp.classList.add('shake');
      inp.focus();
    }
  }

  if (sessionStorage.getItem('lva_auth') === '1') {
    document.getElementById('pw-overlay').classList.add('hidden');
  }

  window.addEventListener('scroll', () => {
    document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 20);
  });

  function toggleMenu() {
    document.getElementById('nav-links').classList.toggle('open');
  }
</script>
</body>
</html>
